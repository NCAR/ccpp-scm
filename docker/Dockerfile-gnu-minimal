FROM ubuntu:24.04

ARG GNU_VERSION=12

# Extend and update the package registry
RUN apt-get update \
 && DEBIAN_FRONTEND=noninteractive apt-get --yes install --no-install-recommends \
      ca-certificates \
      curl \
      wget \
      gpg \
      binutils \
      gfortran-$GNU_VERSION \
      g++ \
      gcc \
      libc-dev \
      make \
      cmake \
      git 

# Set default compiler executables
ENV FC=gfortran CC=gcc CXX=g++

# GNU fortran
ENV NETCDF_FORTRAN_DIR=/usr
ENV LD_LIBRARY_PATH=${NETCDF_FORTRAN_DIR}/lib:$LD_LIBRARY_PATH
